<Window x:Class="BWG_WasteScraper.MainScraperWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BWG Waste Scraper v1.0 - หน้าหลักระบบ" Height="750" Width="900"
        Background="#121214" WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <Grid>
                <TextBlock Text="🎯 WASTE DATA AUTOMATION" FontSize="24" FontWeight="Bold" Foreground="#00FF99"/>
                <TextBlock x:Name="TxtWelcome" Text="ผู้ใช้งานแอป: Admin" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="#8E8E93" FontSize="12"/>
            </Grid>
            <TextBlock Text="ระบบกวาดข้อมูลคำขออัตโนมัติ (เว็บกรมโรงงาน)" FontSize="13" Foreground="#8E8E93" Margin="0,5,0,0"/>
            <Separator Background="#2A2A30" Margin="0,12,0,0"/>
        </StackPanel>
        
        <Border Grid.Row="1" Background="#18181C" BorderBrush="#2A2A30" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="🔑 TARGET WEBSITE AUTHENTICATION &amp; COMPANY SELECTION" FontSize="11" FontWeight="Bold" Foreground="#00FF99" Margin="0,0,0,12"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Web Username" FontSize="11" Foreground="#8E8E93" Margin="0,0,0,5"/>
                        <TextBox x:Name="TxtWebUsername" Background="#2A2A30" Foreground="#E5E5EA" BorderBrush="#3A3A40" Height="32" VerticalContentAlignment="Center" Padding="5,0" CaretBrush="#00FF99"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Text="Web Password" FontSize="11" Foreground="#8E8E93" Margin="0,0,0,5"/>
                        <PasswordBox x:Name="TxtWebPassword" Background="#2A2A30" Foreground="#E5E5EA" BorderBrush="#3A3A40" Height="32" VerticalContentAlignment="Center" Padding="5,0" CaretBrush="#00FF99"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Select Target Company (เลือกบริษัทเป้าหมาย)" FontSize="11" Foreground="#00FF99" Margin="0,0,0,5" FontWeight="SemiBold"/>
                        <ComboBox x:Name="CboCompany" Background="#2A2A30" Foreground="Black" BorderBrush="#3A3A40" Height="32" VerticalContentAlignment="Center" SelectedIndex="0">
                            <ComboBoxItem Content="บริษัท BWG (รหัส: 20190300225401)" Tag="20190300225401"/>
                            <ComboBoxItem Content="บริษัท BWG (รหัส: 10190000825494)" Tag="10190000825494"/>
                            <ComboBoxItem Content="บริษัท BWG (รหัส: 82170100125618)" Tag="82170100125618"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="🖥️ TERMINAL PROCESS LOGS" FontSize="11" FontWeight="Bold" Foreground="#8E8E93" Margin="0,0,0,8"/>
            <Border Grid.Row="1" Background="#18181C" BorderBrush="#2A2A30" BorderThickness="1" CornerRadius="6">
                <ScrollViewer x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto">
                    <TextBox x:Name="TxtLogs" Background="Transparent" Foreground="#E5E5EA" BorderThickness="0" FontFamily="Consolas" FontSize="12.5" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" Margin="12"/>
                </ScrollViewer>
            </Border>
        </Grid>

        <Grid Grid.Row="3" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock x:Name="TxtStatus" Text="🟢 ระบบพร้อมทำงาน..." Foreground="#00FF99" FontSize="13" FontWeight="SemiBold"/>
            </StackPanel>

            <Button Grid.Column="1" x:Name="BtnStart" Content="🚀 เริ่มกวาดข้อมูลคำขอ" Width="180" Height="45" FontSize="14" FontWeight="Bold" Cursor="Hand" Click="BtnStart_Click" Margin="0,0,10,0" Background="#00FF99" Foreground="#040405"/>

            <Button Grid.Column="2" x:Name="BtnExportExcel" Content="📊 รายงาน " Width="180" Height="45" FontSize="14" FontWeight="Bold" Cursor="Hand" Click="BtnExportExcel_Click" Background="#007ACC" Foreground="White">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Grid>
</Window>